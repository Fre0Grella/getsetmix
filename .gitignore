.env
.env.*
*.pem
*.key
*.p12
*.pfx

# Python caches
__pycache__/
*.py[cod]

# IDE/editor files
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Tool caches
.ruff_cache/
